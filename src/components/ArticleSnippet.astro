---
import { formatDateLong, formatReadingTime } from "../lib/utils";

export type Props = {
  title: string;
  description: string;
  url: string;
  time?: number;
  timestamp?: Date;
};

const { title, description, url, time, timestamp } = Astro.props;
---

<a href={url} class="article-row">
  <span class="article-date">
    {timestamp ? formatDateLong(timestamp) : ""}
  </span>
  <div class="article-body">
    <div class="article-title">{title}</div>
    <div class="article-desc">{description}</div>
  </div>
  <span class="article-time">
    {time !== undefined ? formatReadingTime(time) : ""}
  </span>
</a>

<style>
  .article-row {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: 1.4rem;
    align-items: baseline;
    padding: 1rem 0;
    border-top: 1px solid var(--line-soft);
    text-decoration: none;
    transition: background 160ms ease;
  }
  .article-row:hover {
    background: var(--paper-deep);
    text-decoration: none;
  }
  .article-row:hover .article-title { color: var(--accent-deep); }

  .article-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .article-title {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.25rem;
    color: var(--ink);
    transition: color 160ms ease;
  }

  .article-desc {
    color: var(--ink-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .article-time {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    white-space: nowrap;
    align-self: start;
    padding-top: 0.2rem;
  }

  @media (max-width: 540px) {
    .article-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .article-time { display: none; }
  }
</style>
