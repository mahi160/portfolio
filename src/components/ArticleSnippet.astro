---
import { processArticleDate } from "../lib/utils";

export type Props = {
  title: string;
  description: string;
  url: string;
  duration?: string;
  timestamp?: string;
};

const { title, description, url, duration, timestamp } = Astro.props;
const time = duration ? parseInt(duration) : null;
---

<a href={url} class="article-row">
  <span class="article-date">
    {timestamp ? processArticleDate(timestamp) : ""}
  </span>
  <div class="article-body">
    <div class="article-title">{title}</div>
    <div class="article-desc">{description}</div>
  </div>
  <span class="article-time">
    {time !== null ? (time < 1 ? "< 1" : time) : ""}{duration ? " min" : ""}
  </span>
</a>

<style>
  .article-row {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: 1.4rem;
    align-items: baseline;
    padding: 1rem 0;
    border-top: 1px solid var(--line-soft);
    text-decoration: none;
    transition: background 160ms ease;
  }
  .article-row:hover {
    background: var(--paper-deep);
    text-decoration: none;
  }

  .article-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .article-title {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.25rem;
    color: var(--ink);
  }

  .article-desc {
    color: var(--ink-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .article-time {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    white-space: nowrap;
    align-self: start;
    padding-top: 0.2rem;
  }

  @media (max-width: 540px) {
    .article-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .article-time { display: none; }
  }
</style>
