---
import { processArticleDate } from "../lib/utils";
import Anchor from "./common/Anchor.astro";

export type Props = {
  title: string;
  description: string;
  url: string;
  duration?: string;
  timestamp?: string;
};

const { title, description, url, duration, timestamp } = Astro.props;
---

<div class="text-foreground flex flex-col gap-3 py-5 border-b border-border">
  <Anchor url={url} class="text-xl sm:text-2xl font-display font-medium">
    {title}
  </Anchor>
  <p class="text-muted text-base font-sans leading-relaxed max-w-3xl">
    {description}
  </p>
  <div
    class="text-muted flex justify-between items-center text-xs"
  >
    {timestamp ? <p>{processArticleDate(timestamp)}</p> : null}
    {duration ? <p>{duration}</p> : null}
  </div>
</div>
