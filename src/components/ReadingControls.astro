---
// Reading preference controls — font size, font family, spacing
// Persisted to localStorage under "sifat-reading-prefs"
---

<div class="rc-bar" id="rcBar" aria-label="Reading preferences">
  <div class="rc-group" role="group" aria-label="Text size">
    <span class="rc-label" aria-hidden="true">Aa</span>
    <button class="rc-btn" data-rc="size" data-value="sm" aria-pressed="false" aria-label="Small text">Hobbit</button>
    <button class="rc-btn" data-rc="size" data-value="md" aria-pressed="false" aria-label="Medium text">Ranger</button>
    <button class="rc-btn" data-rc="size" data-value="lg" aria-pressed="false" aria-label="Large text">Ent</button>
  </div>

  <div class="rc-sep" aria-hidden="true"></div>

  <div class="rc-group" role="group" aria-label="Font family">
    <button class="rc-btn" data-rc="font" data-value="serif" aria-pressed="false" aria-label="Serif font">Elvish</button>
    <button class="rc-btn" data-rc="font" data-value="sans" aria-pressed="false" aria-label="Sans-serif font">Westron</button>
    <button class="rc-btn" data-rc="font" data-value="lore" aria-pressed="false" aria-label="Display font">Lore</button>
  </div>

  <div class="rc-sep" aria-hidden="true"></div>

  <div class="rc-group" role="group" aria-label="Line spacing">
    <span class="rc-label" aria-hidden="true">↕</span>
    <button class="rc-btn" data-rc="spacing" data-value="cozy" aria-pressed="false" aria-label="Compact spacing">Shire</button>
    <button class="rc-btn" data-rc="spacing" data-value="regular" aria-pressed="false" aria-label="Regular spacing">Rohan</button>
    <button class="rc-btn" data-rc="spacing" data-value="airy" aria-pressed="false" aria-label="Airy spacing">Rivendell</button>
  </div>
</div>

<script>
  const LS_KEY = "sifat-reading-prefs";
  const DEFAULTS = { size: "md", font: "sans", spacing: "regular" };

  const SIZE = {
    sm: { size: "0.94rem",  leading: "1.68" },
    md: { size: "1.075rem", leading: "1.78" },
    lg: { size: "1.22rem",  leading: "1.88" },
  };

  const FONT = {
    serif: '"Lora",Georgia,serif',
    sans:  '"Plus Jakarta Sans",system-ui,-apple-system,sans-serif',
    lore:  '"Cormorant Garamond",Georgia,serif',
  };

  const SPACING = {
    cozy:    { para: "1em",    gap: "1.5rem" },
    regular: { para: "1.25em", gap: "2rem"   },
    airy:    { para: "1.6em",  gap: "2.6rem" },
  };

  function load() {
    try { return { ...DEFAULTS, ...JSON.parse(localStorage.getItem(LS_KEY) || "{}") }; }
    catch { return { ...DEFAULTS }; }
  }

  function save(p: typeof DEFAULTS) {
    localStorage.setItem(LS_KEY, JSON.stringify(p));
  }

  function apply(p: typeof DEFAULTS) {
    const prose = document.querySelector<HTMLElement>(".prose-warm");
    if (!prose) return;

    const s = SIZE[p.size as keyof typeof SIZE] || SIZE.md;
    const sp = SPACING[p.spacing as keyof typeof SPACING] || SPACING.regular;

    prose.style.setProperty("--rc-size",    s.size);
    prose.style.setProperty("--rc-leading", s.leading);
    prose.style.setProperty("--rc-font",    FONT[p.font as keyof typeof FONT] || FONT.sans);
    prose.style.setProperty("--rc-para",    sp.para);
    prose.style.setProperty("--rc-gap",     sp.gap);
    prose.dataset.font = p.font;

    // Sync active states + aria-pressed
    document.querySelectorAll<HTMLElement>("[data-rc]").forEach((btn) => {
      const isActive = p[btn.dataset.rc as keyof typeof p] === btn.dataset.value;
      btn.classList.toggle("rc-active", isActive);
      btn.setAttribute("aria-pressed", String(isActive));
    });
  }

  const prefs = load();
  apply(prefs);

  document.getElementById("rcBar")?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-rc]");
    if (!btn) return;
    const key = btn.dataset.rc as keyof typeof prefs;
    const val = btn.dataset.value as string;
    (prefs as Record<string, string>)[key] = val;
    save(prefs);
    apply(prefs);
  });
</script>

<style>
  .rc-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.8rem;
    padding: 0.45rem 0;
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }

  .rc-group {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .rc-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    margin-right: 0.3rem;
    user-select: none;
  }

  .rc-sep {
    width: 1px;
    height: 0.9rem;
    background: var(--line-soft);
    margin: 0 0.4rem;
    flex-shrink: 0;
  }

  .rc-btn {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
    background: none;
    border: none;
    padding: 0.2rem 0.38rem;
    cursor: pointer;
    border-radius: 3px;
    transition: color 120ms ease, background 120ms ease;
    line-height: 1;
  }

  .rc-btn:hover {
    color: var(--ink-muted);
    background: var(--paper-deep);
  }

  .rc-btn.rc-active {
    color: var(--ink);
    background: var(--paper-deeper);
  }
</style>
