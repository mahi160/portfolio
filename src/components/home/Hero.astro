---
import { GLOBAL } from "../../lib/variables";
---

<section class="hero-section">
  <p class="hero-eyebrow reveal">
    <span>{GLOBAL.currentRole}</span>
    <span class="hero-sep" aria-hidden="true">/</span>
    <span class="hero-loc">Dhaka · GMT+6</span>
  </p>

  <h1 class="hero-headline reveal" style="--reveal-delay: 60ms">
    Frontend by trade.<br />
    <em>Terminal by choice.<span class="hero-caret" aria-hidden="true"></span></em>
  </h1>

  <p class="hero-bio reveal" style="--reveal-delay: 130ms">{GLOBAL.longDescription}</p>

  <div class="hero-links reveal" style="--reveal-delay: 200ms">
    <a href="/blog"     class="arrow-link">Read the writing</a>
    <a href="/projects" class="arrow-link">See the projects</a>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 2rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--line-soft);
    margin-bottom: 3.5rem;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
    margin-bottom: 1.8rem;
    display: flex;
    gap: 0.7rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-sep { color: var(--line); }
  .hero-loc  { color: var(--ink-faint); }

  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5.5vw, 3.8rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 1.8rem;
    color: var(--ink);
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  /* Terminal caret — the one ornament */
  .hero-caret {
    display: inline-block;
    width: 0.45em;
    height: 0.78em;
    margin-left: 0.12em;
    background: var(--accent);
    transform: translateY(0.08em);
    opacity: 0.85;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-caret {
      animation: caret-blink 1.15s steps(1, end) infinite;
      animation-delay: 1.2s;
    }
  }
  @keyframes caret-blink {
    0%, 55% { opacity: 0.85; }
    56%, 100% { opacity: 0; }
  }

  .hero-bio {
    max-width: 38rem;
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--ink-muted);
    margin-bottom: 1.8rem;
  }

  .hero-links {
    display: flex;
    gap: 1.8rem;
    flex-wrap: wrap;
  }
</style>
