---
import { GLOBAL } from "../../lib/variables";
---

<div class="max-w-3xl">
    <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-3">
            <p class="text-xs uppercase tracking-widest font-mono text-muted">
                frontend systems · developer tools · terminal workflows
            </p>
            <h1 class="text-4xl sm:text-5xl font-display font-semibold text-accent leading-tight">
                {GLOBAL.username}
            </h1>
            <h2 class="text-xl sm:text-2xl font-sans font-medium text-foreground leading-relaxed">
                {GLOBAL.shortDescription}
            </h2>
        </div>

        <p class="text-muted text-base sm:text-lg font-sans leading-relaxed">
            {GLOBAL.longDescription}
        </p>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-mono">
            {GLOBAL.githubProfile && (
                <a href={GLOBAL.githubProfile} target="_blank" rel="noreferrer" class="underline-offset-4 underline font-medium hover:text-accent">
                    GitHub
                </a>
            )}
            {GLOBAL.linkedinProfile && (
                <a href={GLOBAL.linkedinProfile} target="_blank" rel="noreferrer" class="underline-offset-4 underline font-medium hover:text-accent">
                    LinkedIn
                </a>
            )}
            {GLOBAL.resumeUrl && (
                <a href={GLOBAL.resumeUrl} target="_blank" rel="noreferrer" class="underline-offset-4 underline font-medium hover:text-accent">
                    Resume
                </a>
            )}
        </div>

        <div class="flex items-center gap-2 text-xs sm:text-sm font-mono text-muted flex-wrap pt-2">
            <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
            <span>currently building</span>
            <a href="https://github.com/mahi160/flowd" target="_blank" rel="noreferrer" class="underline-offset-4 underline font-medium hover:text-accent">flowd</a>
            <span>&</span>
            <a href="https://github.com/mahi160/ki" target="_blank" rel="noreferrer" class="underline-offset-4 underline font-medium hover:text-accent">ki</a>
        </div>
    </div>
</div>
