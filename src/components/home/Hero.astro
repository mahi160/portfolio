---
import { GLOBAL } from "../../lib/variables";
---

<section class="hero-section">

  <!-- meta bar -->
  <div class="hero-meta">
    <span class="meta-role">
      <span class="kicker-dot" aria-hidden="true"></span>
      {GLOBAL.currentRole}
    </span>
    <span class="meta-loc" aria-hidden="true">Dhaka · GMT +6</span>
  </div>

  <!-- full-width headline -->
  <h1 class="hero-headline">
    Frontend by trade.<br />
    <em>Terminal by choice.</em>
  </h1>

  <!-- body row: bio left, dot-accent right -->
  <div class="hero-lower">
    <div class="hero-body">
      <p class="hero-tagline">{GLOBAL.shortDescription}</p>
      <p class="hero-bio">{GLOBAL.longDescription}</p>
      <div class="hero-cta">
        <a href="/blog"     class="arrow-link">Read the writing</a>
        <a href="/projects" class="arrow-link">See the projects</a>
      </div>
    </div>

    <!-- unboxed dot-grid accent -->
    <div class="hero-accent" aria-hidden="true">
      <svg width="80" height="96" viewBox="0 0 80 96" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hero-dotgrid" x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
            <circle cx="8" cy="8" r="1.3" fill="var(--line)" opacity="0.45" />
          </pattern>
        </defs>
        <rect width="80" height="96" fill="url(#hero-dotgrid)" />
        <!-- medium emphasis -->
        <circle cx="24" cy="24" r="1.9" fill="var(--line)" />
        <circle cx="56" cy="40" r="1.9" fill="var(--line)" />
        <circle cx="8"  cy="56" r="1.9" fill="var(--line)" />
        <circle cx="72" cy="72" r="1.9" fill="var(--line)" />
        <circle cx="40" cy="88" r="1.9" fill="var(--line)" />
        <!-- accent scatter -->
        <circle cx="8"  cy="24" r="2.4" fill="var(--accent-soft)" />
        <circle cx="56" cy="8"  r="2.4" fill="var(--accent-soft)" />
        <circle cx="40" cy="56" r="2.4" fill="var(--accent-soft)" />
        <circle cx="72" cy="40" r="2.4" fill="var(--accent-soft)" />
        <circle cx="24" cy="72" r="2.4" fill="var(--accent-soft)" />
        <!-- bright focal -->
        <circle cx="40" cy="32" r="2.2" fill="var(--accent)" />
        <circle cx="24" cy="80" r="2.2" fill="var(--accent)" />
      </svg>
    </div>
  </div>

</section>

<style>
  .hero-section {
    padding-top: 1.8rem;
    padding-bottom: 3.5rem;
  }

  /* ── Meta bar ─────────────────────────────────────────────────────── */
  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
    margin-bottom: 2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .meta-role {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--accent-deep);
  }

  .meta-loc {
    color: var(--ink-faint);
  }

  .kicker-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    flex-shrink: 0;
  }

  /* ── Headline ─────────────────────────────────────────────────────── */
  .hero-headline {
    font-size: clamp(2.6rem, 5.5vw, 4.2rem);
    line-height: 1.06;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 0;
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  /* ── Lower row ────────────────────────────────────────────────────── */
  .hero-lower {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem 3rem;
    align-items: end;
    border-top: 1px solid var(--line-soft);
    margin-top: 2rem;
    padding-top: 1.8rem;
  }

  .hero-body { max-width: 44rem; }

  .hero-tagline {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }

  .hero-bio {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--ink-muted);
    margin-bottom: 1.4rem;
    max-width: 38rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Dot accent ───────────────────────────────────────────────────── */
  .hero-accent {
    align-self: end;
    padding-bottom: 0.2rem;
    opacity: 0.9;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero-lower  { grid-template-columns: 1fr; }
    .hero-accent { display: none; }
    .meta-loc    { display: none; }
  }
</style>
