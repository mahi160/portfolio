---
import { GLOBAL } from "../../lib/variables";
---

<section class="hero-section">

  <div class="hero-meta">
    <span class="meta-role">
      <span class="kicker-dot" aria-hidden="true"></span>
      {GLOBAL.currentRole}
    </span>
    <span class="meta-loc" aria-hidden="true">Dhaka · GMT +6</span>
  </div>

  <h1 class="hero-headline">
    Frontend by trade.<br />
    <em>Terminal by choice.</em>
  </h1>

  <div class="hero-lower">
    <p class="hero-bio">{GLOBAL.longDescription}</p>
    <div class="hero-cta">
      <a href="/blog"     class="arrow-link">Read the writing</a>
      <a href="/projects" class="arrow-link">See the projects</a>
    </div>
  </div>

</section>

<style>
  .hero-section {
    padding-top: 1.8rem;
    padding-bottom: 3.5rem;
  }

  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .meta-role {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--accent-deep);
  }

  .meta-loc { color: var(--ink-faint); }

  .kicker-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    flex-shrink: 0;
  }

  .hero-headline {
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 1.06;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 0;
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  .hero-lower {
    border-top: 1px solid var(--line-soft);
    margin-top: 2rem;
    padding-top: 1.6rem;
    max-width: 48rem;
  }

  .hero-bio {
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--ink-muted);
    margin-bottom: 1.4rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  @media (max-width: 540px) {
    .meta-loc { display: none; }
  }
</style>
