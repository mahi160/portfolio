---
import { GLOBAL } from "../../lib/variables";

const icons = [
  { name: "HTML",       slug: "html5",           top:  "1%", left:  48, size: 28, opacity: 0.38, rotate: -14 },
  { name: "Tailwind",   slug: "tailwindcss",      top:  "3%", left: 152, size: 20, opacity: 0.30, rotate:  10 },
  { name: "CSS",        slug: "css3",             top:  "8%", left:  98, size: 18, opacity: 0.28, rotate:  -6 },
  { name: "tmux",       slug: "tmux",             top:  "6%", left: 188, size: 22, opacity: 0.32, rotate:  19 },
  { name: "JavaScript", slug: "javascript",       top: "14%", left:  18, size: 26, opacity: 0.38, rotate:  16 },
  { name: "TypeScript", slug: "typescript",       top: "17%", left: 130, size: 22, opacity: 0.30, rotate:  -9 },
  { name: "Node.js",    slug: "nodedotjs",        top: "22%", left: 178, size: 20, opacity: 0.26, rotate:  22 },
  { name: "Astro",      slug: "astro",            top: "24%", left:  72, size: 24, opacity: 0.34, rotate:  -5 },
  { name: "React",      slug: "react",            top: "31%", left:  28, size: 32, opacity: 0.44, rotate: -20 },
  { name: "SQLite",     slug: "sqlite",           top: "34%", left: 148, size: 22, opacity: 0.30, rotate:  13 },
  { name: "Angular",    slug: "angular",          top: "40%", left:  95, size: 26, opacity: 0.36, rotate: -17 },
  { name: "GitHub",     slug: "github",           top: "42%", left: 188, size: 18, opacity: 0.24, rotate:   8 },
  { name: "Go",         slug: "go",               top: "48%", left:  12, size: 30, opacity: 0.40, rotate:  -4 },
  { name: "Lua",        slug: "lua",              top: "51%", left: 162, size: 20, opacity: 0.28, rotate:  24 },
  { name: "Git",        slug: "git",              top: "57%", left:  60, size: 22, opacity: 0.32, rotate: -13 },
  { name: "Bash",       slug: "gnubash",          top: "60%", left: 130, size: 24, opacity: 0.36, rotate:  11 },
  { name: "Neovim",     slug: "neovim",           top: "66%", left:  22, size: 28, opacity: 0.42, rotate: -21 },
  { name: "Docker",     slug: "docker",           top: "70%", left: 178, size: 22, opacity: 0.28, rotate:  16 },
  { name: "Linux",      slug: "linux",            top: "75%", left:  92, size: 26, opacity: 0.34, rotate:  -8 },
  { name: "Bun",        slug: "bun",              top: "78%", left: 158, size: 18, opacity: 0.26, rotate:  20 },
  { name: "macOS",      slug: "apple",            top: "84%", left:  38, size: 24, opacity: 0.32, rotate:   7 },
  { name: "Rust",       slug: "rust",             top: "86%", left: 115, size: 20, opacity: 0.28, rotate: -15 },
  { name: "Claude",     slug: "anthropic",        top: "91%", left: 178, size: 26, opacity: 0.36, rotate:  12 },
  { name: "Python",     slug: "python",           top: "94%", left:  68, size: 22, opacity: 0.30, rotate: -10 },
];
---

<section class="hero-section">

  <div class="hero-meta">
    <span class="meta-role">
      <span class="kicker-dot" aria-hidden="true"></span>
      {GLOBAL.currentRole}
    </span>
    <span class="meta-loc" aria-hidden="true">Dhaka · GMT +6</span>
  </div>

  <div class="hero-grid">

    <div class="hero-text">
      <h1 class="hero-headline">
        Frontend by trade.<br />
        <em>Terminal by choice.</em>
      </h1>
      <div class="hero-lower">
        <p class="hero-bio">{GLOBAL.longDescription}</p>
        <div class="hero-cta">
          <a href="/blog"     class="arrow-link">Read the writing</a>
          <a href="/projects" class="arrow-link">See the projects</a>
        </div>
      </div>
    </div>

    <div class="hero-icons" aria-hidden="true">
      {icons.map((icon) => (
        <img
          src={`https://cdn.simpleicons.org/${icon.slug}`}
          alt=""
          width={icon.size}
          height={icon.size}
          class="tech-icon"
          style={`top:${icon.top}; left:${icon.left}px; width:${icon.size}px; height:${icon.size}px; opacity:${icon.opacity}; transform:rotate(${icon.rotate}deg);`}
          loading="lazy"
        />
      ))}
    </div>

  </div>

</section>

<style>
  .hero-section {
    padding-top: 1.8rem;
    padding-bottom: 3.5rem;
  }

  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .meta-role {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--accent-deep);
  }

  .meta-loc { color: var(--ink-faint); }

  .kicker-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    flex-shrink: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 2rem;
    align-items: stretch;
  }

  .hero-headline {
    font-size: clamp(2.4rem, 4.8vw, 3.8rem);
    line-height: 1.06;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 0;
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  .hero-lower {
    border-top: 1px solid var(--line-soft);
    margin-top: 1.8rem;
    padding-top: 1.5rem;
    max-width: 42rem;
  }

  .hero-bio {
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--ink-muted);
    margin-bottom: 1.4rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Scattered icons ──────────────────────────────────────────────── */
  .hero-icons {
    position: relative;
    overflow: hidden;
  }

  .tech-icon {
    position: absolute;
    filter: grayscale(1) brightness(0.3);
    pointer-events: none;
    user-select: none;
  }

  :global([data-theme="dark"]) .tech-icon {
    filter: grayscale(1) brightness(3) invert(0.85);
  }

  @media (max-width: 700px) {
    .hero-grid  { grid-template-columns: 1fr; }
    .hero-icons { display: none; }
    .meta-loc   { display: none; }
  }
</style>
