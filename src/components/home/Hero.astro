---
import { GLOBAL } from "../../lib/variables";

const icons = [
  { name: "HTML",       slug: "html5",      top: "3%",  left: 18,  size: 26, opacity: 0.14 },
  { name: "CSS",        slug: "css3",        top: "2%",  left: 148, size: 20, opacity: 0.10 },
  { name: "JavaScript", slug: "javascript",  top: "18%", left: 82,  size: 30, opacity: 0.16 },
  { name: "TypeScript", slug: "typescript",  top: "15%", left: 172, size: 22, opacity: 0.11 },
  { name: "React",      slug: "react",       top: "34%", left: 28,  size: 26, opacity: 0.13 },
  { name: "Angular",    slug: "angular",     top: "31%", left: 138, size: 20, opacity: 0.09 },
  { name: "Go",         slug: "go",          top: "50%", left: 68,  size: 28, opacity: 0.15 },
  { name: "Git",        slug: "git",         top: "48%", left: 182, size: 18, opacity: 0.10 },
  { name: "Neovim",     slug: "neovim",      top: "65%", left: 12,  size: 24, opacity: 0.12 },
  { name: "Linux",      slug: "linux",       top: "67%", left: 122, size: 26, opacity: 0.13 },
  { name: "macOS",      slug: "apple",       top: "83%", left: 52,  size: 20, opacity: 0.10 },
  { name: "Claude",     slug: "anthropic",   top: "80%", left: 178, size: 24, opacity: 0.12 },
];
---

<section class="hero-section">

  <div class="hero-meta">
    <span class="meta-role">
      <span class="kicker-dot" aria-hidden="true"></span>
      {GLOBAL.currentRole}
    </span>
    <span class="meta-loc" aria-hidden="true">Dhaka · GMT +6</span>
  </div>

  <div class="hero-grid">

    <div class="hero-text">
      <h1 class="hero-headline">
        Frontend by trade.<br />
        <em>Terminal by choice.</em>
      </h1>
      <div class="hero-lower">
        <p class="hero-bio">{GLOBAL.longDescription}</p>
        <div class="hero-cta">
          <a href="/blog"     class="arrow-link">Read the writing</a>
          <a href="/projects" class="arrow-link">See the projects</a>
        </div>
      </div>
    </div>

    <div class="hero-icons" aria-hidden="true">
      {icons.map((icon) => (
        <img
          src={`https://cdn.simpleicons.org/${icon.slug}`}
          alt=""
          width={icon.size}
          height={icon.size}
          class="tech-icon"
          style={`top:${icon.top}; left:${icon.left}px; width:${icon.size}px; height:${icon.size}px; opacity:${icon.opacity};`}
          loading="lazy"
        />
      ))}
    </div>

  </div>

</section>

<style>
  .hero-section {
    padding-top: 1.8rem;
    padding-bottom: 3.5rem;
  }

  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .meta-role {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--accent-deep);
  }

  .meta-loc { color: var(--ink-faint); }

  .kicker-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    flex-shrink: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 2rem;
    align-items: stretch;
  }

  .hero-headline {
    font-size: clamp(2.4rem, 4.8vw, 3.8rem);
    line-height: 1.06;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 0;
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  .hero-lower {
    border-top: 1px solid var(--line-soft);
    margin-top: 1.8rem;
    padding-top: 1.5rem;
    max-width: 42rem;
  }

  .hero-bio {
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--ink-muted);
    margin-bottom: 1.4rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Scattered icons ──────────────────────────────────────────────── */
  .hero-icons {
    position: relative;
    overflow: hidden;
  }

  .tech-icon {
    position: absolute;
    filter: grayscale(1) brightness(0.3);
    pointer-events: none;
    user-select: none;
  }

  :global([data-theme="dark"]) .tech-icon {
    filter: grayscale(1) brightness(3) invert(0.85);
  }

  @media (max-width: 700px) {
    .hero-grid  { grid-template-columns: 1fr; }
    .hero-icons { display: none; }
    .meta-loc   { display: none; }
  }
</style>
