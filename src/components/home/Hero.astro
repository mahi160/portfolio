---
import { GLOBAL } from "../../lib/variables";
---

<section class="hero-section">
  <p class="hero-eyebrow">
    <span>{GLOBAL.currentRole}</span>
    <span class="hero-sep" aria-hidden="true">/</span>
    <span class="hero-loc">Dhaka · GMT+6</span>
  </p>

  <h1 class="hero-headline">
    Frontend by trade.<br />
    <em>Terminal by choice.</em>
  </h1>

  <p class="hero-bio">{GLOBAL.longDescription}</p>

  <div class="hero-links">
    <a href="/blog"     class="arrow-link">Read the writing</a>
    <a href="/projects" class="arrow-link">See the projects</a>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 2rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--line-soft);
    margin-bottom: 3.5rem;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
    margin-bottom: 1.8rem;
    display: flex;
    gap: 0.7rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-sep { color: var(--line); }
  .hero-loc  { color: var(--ink-faint); }

  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5.5vw, 3.8rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    font-weight: 600;
    margin-bottom: 1.8rem;
    color: var(--ink);
  }

  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-deep);
  }

  .hero-bio {
    max-width: 38rem;
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--ink-muted);
    margin-bottom: 1.8rem;
  }

  .hero-links {
    display: flex;
    gap: 1.8rem;
    flex-wrap: wrap;
  }
</style>
