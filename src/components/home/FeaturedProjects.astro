---
import type { ProjectFrontmatter } from "../../lib/types";
import { GLOBAL } from "../../lib/variables";
import Anchor from "../common/Anchor.astro";
import ProjectSnippet from "../ProjectSnippet.astro";

type Props = {
  featuredProjects: Array<ProjectFrontmatter>;
}

const { featuredProjects } = Astro.props;
---

<div class="flex flex-col gap-2 mb-8">
  <p class="text-xs uppercase tracking-widest font-mono text-muted">
    Open source & explorations
  </p>
  <div class="flex justify-between items-end gap-6">
    <h3 class="font-display text-4xl sm:text-5xl leading-tight text-accent">{GLOBAL.projectsName}</h3>
    <Anchor url="/projects" class="text-sm shrink-0">{GLOBAL.viewAll}</Anchor>
  </div>
</div>
<ul>
  {
    (featuredProjects.length === 0 && <p>{GLOBAL.noProjects}</p>) ||
      featuredProjects.map((project) => (
        <li>
          <ProjectSnippet
            title={project.title}
            description={project.description}
            url={project.filename}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            tags={project.tags ?? []}
          />
        </li>
      ))
  }
</ul>