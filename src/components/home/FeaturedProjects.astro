---
import type { ProjectFrontmatter } from "../../lib/types";

type Props = {
  featuredProjects: Array<ProjectFrontmatter>;
}

const { featuredProjects } = Astro.props;

function fmtMonthYear(iso: string) {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
  } catch { return iso; }
}
---

<section class="featured-projects">
  <div class="section-head">
    <div>
      <div class="section-kicker">Selected</div>
      <h2 class="section-title">Projects</h2>
    </div>
    <a href="/projects" class="arrow-link">All projects</a>
  </div>

  <div class="projects-grid">
    {featuredProjects.map((project) => (
      <a href={project.filename} class="project-card">
        <div class="card-top">
          <span class="card-title">{project.title}</span>
          <span class="card-date">{fmtMonthYear(project.timestamp)}</span>
        </div>
        <p class="card-desc">{project.description}</p>
        {project.tags && project.tags.length > 0 && (
          <div class="card-tags">
            {project.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        )}
      </a>
    ))}
  </div>
</section>

<style>
  .featured-projects {
    margin-bottom: 1rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .section-kicker {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.35rem;
  }

  .section-title {
    font-size: 1.55rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1.4rem;
  }

  .project-card {
    display: block;
    padding: 1.2rem 1.3rem 1.1rem;
    text-decoration: none;
    background: var(--paper-deep);
    border: 1px solid var(--line-soft);
    border-radius: 6px;
    transition: border-color 200ms ease;
  }
  .project-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: var(--mono);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
  }

  .card-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
  }

  .card-desc {
    color: var(--ink-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin-bottom: 0.7rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.65em;
  }
</style>
