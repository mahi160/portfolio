---
import type { ArticleEntry } from "../../lib/types";
import { formatDateLong, formatReadingTime } from "../../lib/utils";

type Props = {
  featuredArticles: ArticleEntry[];
};

const { featuredArticles } = Astro.props;
---

<section class="featured-writing">
  <div class="section-head">
    <div>
      <div class="section-kicker">Recent</div>
      <h2 class="section-title">Writing</h2>
    </div>
    <a href="/blog" class="arrow-link">All writing</a>
  </div>

  <div class="article-list">
    {featuredArticles.map((article) => (
      <a href={article.url} class="article-card">
        <div class="article-meta">
          {formatDateLong(article.timestamp)}
          &nbsp;·&nbsp;
          {formatReadingTime(article.time)}
        </div>
        <div class="article-title">{article.title}</div>
        <div class="article-desc">{article.description}</div>
      </a>
    ))}
    <div class="list-cap" aria-hidden="true"></div>
  </div>
</section>

<style>
  .featured-writing {
    margin-bottom: 3.5rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .section-kicker {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.35rem;
  }

  .section-title {
    font-size: 1.55rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
  }

  .article-list {
    display: flex;
    flex-direction: column;
  }

  .article-card {
    display: block;
    padding: 1.1rem 0.6rem;
    margin: 0 -0.6rem;
    border-top: 1px solid var(--line-soft);
    border-radius: 4px;
    text-decoration: none;
    transition: background 160ms ease;
  }
  .article-card:hover {
    background: var(--paper-deep);
    text-decoration: none;
  }
  .article-card:hover .article-title { color: var(--accent-deep); }

  .article-meta {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
    margin-bottom: 0.55rem;
    letter-spacing: 0.04em;
  }

  .article-title {
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.3rem;
    color: var(--ink);
    transition: color 160ms ease;
  }

  .article-desc {
    color: var(--ink-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .list-cap {
    border-top: 1px solid var(--line-soft);
  }
</style>
