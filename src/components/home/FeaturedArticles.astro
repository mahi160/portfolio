---
import type { ArticleFrontmatter } from "../../lib/types";
import { processArticleDate } from "../../lib/utils";
import { GLOBAL } from "../../lib/variables";
import Anchor from "../common/Anchor.astro";

type Props = {
  featuredArticles: Array<ArticleFrontmatter>;
}

const { featuredArticles } = Astro.props;
const [hero, ...rest] = featuredArticles;
---

<section class="max-w-[var(--content-width)]">
  <div class="flex flex-col gap-2 mb-8">
    <p class="text-xs uppercase tracking-[0.2em] font-mono zag-muted zag-transition">
      Notes from the workshop
    </p>
    <div class="flex justify-between items-end gap-6">
      <h3 class="font-display text-3xl sm:text-4xl leading-tight text-zag-accent-dark dark:text-zag-accent-light">
        {GLOBAL.articlesName}
      </h3>
      <Anchor url="/blog" class="text-sm shrink-0">{GLOBAL.viewAll}</Anchor>
    </div>
  </div>

  {featuredArticles.length === 0 ? (
    <p class="zag-muted zag-transition">{GLOBAL.noArticles}</p>
  ) : (
    <div class="flex flex-col gap-10">
      {hero && (
        <a href={hero.filename} class="block group zag-border-b zag-transition pb-8">
          <article class="flex flex-col gap-4">
            <div class="flex items-center gap-2 text-xs font-mono zag-muted zag-transition uppercase tracking-widest">
              <span>Featured</span>
              <span>·</span>
              <span>{processArticleDate(hero.timestamp)}</span>
              <span>·</span>
              <span>{hero.time} min read</span>
            </div>

            <h4 class="text-2xl sm:text-3xl font-display leading-tight group-hover:text-zag-accent-dark dark:group-hover:text-zag-accent-light zag-transition zag-text">
              {hero.title}
            </h4>

            <p class="zag-muted zag-transition text-sm sm:text-base font-mono leading-7">
              {hero.description}
            </p>

            <span class="text-sm font-mono font-medium text-zag-accent-dark dark:text-zag-accent-light zag-offset underline underline-offset-4">
              Read article →
            </span>
          </article>
        </a>
      )}

      {rest.length > 0 && (
        <ul class="flex flex-col gap-5">
          {rest.map((article) => (
            <li class="grid gap-2 sm:grid-cols-[1fr_auto] sm:items-baseline border-b border-zag-dark/15 dark:border-zag-light/15 pb-5">
              <Anchor url={article.filename} class="text-base font-mono">
                {article.title}
              </Anchor>
              <span class="text-xs font-mono zag-muted zag-transition shrink-0">
                {processArticleDate(article.timestamp)} · {article.time} min
              </span>
            </li>
          ))}
        </ul>
      )}
    </div>
  )}
</section>
