---
import { GLOBAL } from "../lib/variables";

const pathname = Astro.url?.pathname ?? "/";
const isHome     = pathname === "/";
const isWriting  = pathname.startsWith("/blog");
const isProjects = pathname.startsWith("/projects");
---

<header class="site-header">
  <div class="wrap header-inner">
    <!-- Logo / name -->
    <a href="/" class="header-logo">
      <span class="logo-dot" aria-hidden="true"></span>
      <span class="logo-name">Sifat</span>
      <span class="logo-handle">{GLOBAL.handle ?? "sifat.is-a.dev"}</span>
    </a>

    <!-- Nav -->
    <nav class="header-nav">
      <a href="/"         class:list={["nav-link", { active: isHome }]}>Index</a>
      <a href="/blog"     class:list={["nav-link", { active: isWriting }]}>Writing</a>
      <a href="/projects" class:list={["nav-link", { active: isProjects }]}>Projects</a>
      <a href={GLOBAL.resumeUrl} target="_blank" rel="noopener" class="nav-link">Résumé</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding-top: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line-soft);
    margin-bottom: 2.5rem;
  }

  .header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .header-logo {
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .header-logo:hover { text-decoration: none; }

  .logo-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateY(-1px);
    flex-shrink: 0;
  }

  .logo-name {
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--ink);
  }

  .logo-handle {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    margin-left: 0.2rem;
    white-space: nowrap;
  }

  .header-nav {
    display: flex;
    gap: 1.6rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .nav-link:hover {
    color: var(--ink);
    text-decoration: none;
    border-bottom-color: var(--line);
  }
  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 540px) {
    .header-inner { flex-direction: column; gap: 1rem; }
    .logo-handle { display: none; }
    .header-nav { gap: 1rem; }
  }
</style>
