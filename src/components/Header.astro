---
import { GLOBAL } from "../lib/variables";

const pathname = Astro.url?.pathname ?? "/";
const isHome     = pathname === "/";
const isWriting  = pathname.startsWith("/blog");
const isProjects = pathname.startsWith("/projects");
const isUses     = pathname.startsWith("/uses");
---

<header class="site-header">
  <div class="wrap-narrow header-inner">
    <!-- Logo / name -->
    <a href="/" class="header-logo" aria-label="Sifat — home">
      <span class="logo-name" aria-hidden="true">Sifat</span>
      <span class="logo-handle" aria-hidden="true">{GLOBAL.handle ?? "sifat.is-a.dev"}</span>
    </a>

    <!-- Nav -->
    <nav class="header-nav">
      <a href="/"         class:list={["nav-link", { active: isHome }]}>Index</a>
      <a href="/blog"     class:list={["nav-link", { active: isWriting }]}>Writing</a>
      <a href="/projects" class:list={["nav-link", { active: isProjects }]}>Projects</a>
      <a href="/uses"     class:list={["nav-link", { active: isUses }]}>Uses</a>
      <a href={GLOBAL.resumeUrl} target="_blank" rel="noopener" class="nav-link" aria-label="Résumé, opens in new tab">Résumé</a>
      <button class="theme-toggle" id="themeToggle" aria-label="Switch to dark mode" aria-pressed="false">
        <span class="theme-icon theme-icon-light" aria-hidden="true">○</span>
        <span class="theme-icon theme-icon-dark"  aria-hidden="true">●</span>
        <span class="theme-icon theme-icon-neon"  aria-hidden="true">⧆</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn  = document.getElementById("themeToggle");
  const root = document.documentElement;

  function getTheme(): string {
    return localStorage.getItem("sifat-theme") ||
      (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  }

  function applyTheme(theme: string) {
    root.setAttribute("data-theme", theme === "light" ? "" : theme);
    const labels: Record<string, string> = {
      light: "Switch to dark mode",
      dark:  "Switch to light mode",
      neon:  "Exit neon mode",
    };
    btn?.setAttribute("aria-pressed", String(theme !== "light"));
    btn?.setAttribute("aria-label", labels[theme] ?? "Toggle theme");
  }

  applyTheme(getTheme());

  // Normal toggle: light ↔ dark. Neon exits to light.
  // Triple-click activates neon as an easter egg.
  let clicks = 0;
  let clickTimer: ReturnType<typeof setTimeout> | null = null;

  btn?.addEventListener("click", () => {
    clicks++;
    if (clickTimer) clearTimeout(clickTimer);
    clickTimer = setTimeout(() => { clicks = 0; }, 600);

    const current = getTheme();

    // Easter egg: triple-click enters neon
    if (clicks >= 3 && current !== "neon") {
      clicks = 0;
      localStorage.setItem("sifat-theme", "neon");
      applyTheme("neon");
      const el = document.createElement("div");
      el.className = "neon-toast";
      el.textContent = "// triple-click: neon mode";
      document.body.appendChild(el);
      setTimeout(() => el.classList.add("neon-toast--out"), 2200);
      setTimeout(() => el.remove(), 3100);
      return;
    }

    const next = current === "dark" ? "light" : current === "neon" ? "light" : "dark";
    localStorage.setItem("sifat-theme", next);
    applyTheme(next);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding-top: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line-soft);
    margin-bottom: 2.5rem;
    background: color-mix(in oklab, var(--paper) 86%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .header-logo {
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .header-logo:hover { text-decoration: none; }

  .logo-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateY(-1px);
    flex-shrink: 0;
  }

  .logo-name {
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--ink);
  }

  .logo-handle {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    margin-left: 0.2rem;
    white-space: nowrap;
  }

  .header-nav {
    display: flex;
    gap: 1.6rem;
    align-items: baseline;
  }

  .nav-link {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .nav-link:hover {
    color: var(--ink);
    text-decoration: none;
    border-bottom-color: var(--line);
  }
  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .theme-toggle {
    font-family: var(--mono);
    font-size: 0.85rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.15rem 0.3rem;
    color: var(--ink-faint);
    line-height: 1;
    border-radius: 3px;
    transition: color 160ms ease;
    display: flex;
    align-items: center;
  }
  .theme-toggle:hover { color: var(--ink-muted); }

  .theme-icon { display: none; }

  :root:not([data-theme="dark"]):not([data-theme="neon"]) .theme-icon-light { display: inline; }
  :root[data-theme="dark"]  .theme-icon-dark { display: inline; }
  :root[data-theme="neon"]  .theme-icon-neon { display: inline; color: #00ffe0; }

  @media (max-width: 540px) {
    /* Stacked header is tall — don't pin it on small screens */
    .site-header { position: static; }
    .header-inner { flex-direction: column; gap: 1rem; }
    .logo-handle { display: none; }
    .header-nav { gap: 1rem; }
  }
</style>
