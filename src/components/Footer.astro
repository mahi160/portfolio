---
import { GLOBAL } from "../lib/variables";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap-narrow footer-inner">
    <nav class="footer-links" aria-label="Social links">
      {GLOBAL.githubProfile   && <a href={GLOBAL.githubProfile}   target="_blank" rel="noopener" aria-label="GitHub, opens in new tab">GitHub</a>}
      {GLOBAL.linkedinProfile && <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener" aria-label="LinkedIn, opens in new tab">LinkedIn</a>}
      <a href={`mailto:${GLOBAL.email ?? "hello@sifat.is-a.dev"}`}>Email</a>
      {GLOBAL.resumeUrl && <a href={GLOBAL.resumeUrl} target="_blank" rel="noopener" aria-label="Résumé, opens in new tab">Résumé</a>}
    </nav>
    <p class="footer-copy">
      © {year} Sifat · Dhaka<span id="dhakaClock" class="footer-clock"></span>
    </p>
  </div>
</footer>

<script>
  const el = document.getElementById("dhakaClock");
  const fmt = new Intl.DateTimeFormat("en-GB", {
    hour: "2-digit",
    minute: "2-digit",
    timeZone: "Asia/Dhaka",
  });
  function tick() {
    if (el) el.textContent = ` · ${fmt.format(new Date())} local`;
  }
  tick();
  setInterval(tick, 30_000);
</script>

<style>
  .site-footer {
    margin-top: 3rem;
    padding: 1.2rem 0 1.8rem;
    border-top: 1px solid var(--line-soft);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-links {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .footer-links a:hover {
    color: var(--ink);
    text-decoration: none;
  }

  .footer-copy {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin: 0;
  }

  .footer-clock {
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 480px) {
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
  }
</style>
