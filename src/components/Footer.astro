---
import { GLOBAL } from "../lib/variables";
import Anchor from "./common/Anchor.astro";
import Section from "./common/Section.astro";

const date = new Date();
const year = date.getFullYear();
---

<footer class="mt-16 mb-8">
    <Section class="mb-4">
        <div class="zag-border-b zag-transition pb-5 flex flex-col sm:flex-row justify-between gap-5 sm:items-center">
            <ul class="flex flex-row gap-5 text-sm">
                {Object.entries(GLOBAL.menu).map((i) => (
                    <li>
                        <Anchor url={i[1]}>{i[0]}</Anchor>
                    </li>
                ))}
            </ul>

            <div class="flex flex-row gap-4 items-center">
                {GLOBAL.resumeUrl && (
                    <a href={GLOBAL.resumeUrl} target="_blank" rel="noreferrer" aria-label="Resume" class="focus:outline-2 focus:outline-offset-2 focus:outline-zag-dark dark:focus:outline-zag-light">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                            <path class="zag-fill zag-transition" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm-1 1.5L18.5 9H13zM6 20V4h5v7h7v9z"/>
                        </svg>
                    </a>
                )}
                {GLOBAL.githubProfile && (
                    <a href={GLOBAL.githubProfile} target="_blank" rel="noreferrer" aria-label="GitHub" class="focus:outline-2 focus:outline-offset-2 focus:outline-zag-dark dark:focus:outline-zag-light">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                            <path class="zag-fill zag-transition" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
                        </svg>
                    </a>
                )}
                {GLOBAL.linkedinProfile && (
                    <a href={GLOBAL.linkedinProfile} target="_blank" rel="noreferrer" aria-label="LinkedIn" class="focus:outline-2 focus:outline-offset-2 focus:outline-zag-dark dark:focus:outline-zag-light">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 50 50">
                            <path class="zag-fill zag-transition" d="M41,4H9C6.24,4,4,6.24,4,9v32c0,2.76,2.24,5,5,5h32c2.76,0,5-2.24,5-5V9C46,6.24,43.76,4,41,4z M17,20v19h-6V20H17z M11,14.47c0-1.4,1.2-2.47,3-2.47s2.93,1.07,3,2.47c0,1.4-1.12,2.53-3,2.53C12.2,17,11,15.87,11,14.47z M39,39h-6c0,0,0-9.26,0-10 c0-2-1-4-3.5-4.04h-0.08C27,24.96,26,27.02,26,29c0,0.91,0,10,0,10h-6V20h6v2.56c0,0,1.93-2.56,5.81-2.56 c3.97,0,7.19,2.73,7.19,8.26V39z"/>
                        </svg>
                    </a>
                )}
            </div>
        </div>
    </Section>
    <div class="zag-text zag-transition text-center text-xs font-medium zag-muted flex flex-col gap-1">
        {GLOBAL.currentRole && <p>{GLOBAL.currentRole}</p>}
        <p>&copy; {year} {GLOBAL.username}</p>
    </div>
</footer>
