---
import { GLOBAL } from "../lib/variables";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-elsewhere">
      <div class="elsewhere-label">Elsewhere</div>
      <div class="elsewhere-links">
        {GLOBAL.githubProfile   && <a href={GLOBAL.githubProfile}   target="_blank" rel="noopener">GitHub</a>}
        {GLOBAL.linkedinProfile && <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener">LinkedIn</a>}
        <a href={`mailto:${GLOBAL.email ?? "hello@sifat.is-a.dev"}`}>Email</a>
        {GLOBAL.resumeUrl && <a href={GLOBAL.resumeUrl} target="_blank" rel="noopener">Résumé</a>}
      </div>
    </div>

    <div class="footer-copy">
      <div>© {year} Salauddin Omar Sifat</div>
      <div class="footer-location">Tended in Dhaka.</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding-top: 1.6rem;
    padding-bottom: 2rem;
    border-top: 1px solid var(--line-soft);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .elsewhere-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
  }

  .elsewhere-links {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .elsewhere-links a {
    font-size: 0.95rem;
    color: var(--ink-muted);
    text-decoration: none;
  }
  .elsewhere-links a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  .footer-copy {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    text-align: right;
  }
  .footer-location { margin-top: 0.3rem; }

  @media (max-width: 540px) {
    .footer-copy { text-align: left; }
  }
</style>
