---
import { formatMonthYear } from "../lib/utils";

export type Props = {
  title: string;
  description: string;
  url: string;
  tags: string[];
  timestamp?: Date;
};

const { title, description, url, tags, timestamp } = Astro.props;
---

<a href={url} class="project-row">
  <div class="project-main">
    <div class="project-top">
      <span class="project-title">{title}</span>
      {timestamp && <span class="project-date">{formatMonthYear(timestamp)}</span>}
    </div>
    <div class="project-desc">{description}</div>
    {tags.length > 0 && (
      <div class="project-tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
  <span class="project-read arrow-link">Read</span>
</a>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.2rem 1.5rem;
    padding: 1.2rem 0.6rem;
    margin: 0 -0.6rem;
    border-top: 1px solid var(--line-soft);
    border-radius: 4px;
    text-decoration: none;
    align-items: baseline;
    transition: background 160ms ease;
  }
  .project-row:hover {
    background: var(--paper-deep);
    text-decoration: none;
  }
  .project-row:hover .project-title { color: var(--accent-deep); }

  .project-top {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin-bottom: 0.45rem;
  }

  .project-title {
    font-family: var(--mono);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    transition: color 160ms ease;
  }

  .project-date {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
  }

  .project-desc {
    color: var(--ink-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    margin-bottom: 0.5rem;
    max-width: 42rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.65em;
  }

  .project-read {
    align-self: center;
  }

  @media (max-width: 540px) {
    .project-row { grid-template-columns: 1fr; }
    .project-read { display: none; }
  }
</style>
