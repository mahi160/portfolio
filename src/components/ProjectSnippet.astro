---
import Anchor from "./common/Anchor.astro";

export type Props = {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  liveUrl?: string;
  tags: string[];
};

const { title, description, url, githubUrl, liveUrl, tags } = Astro.props;
---

<div class="flex flex-col gap-3 py-5 border-b border-border">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <Anchor url={url} class="text-xl sm:text-2xl font-display font-medium">
      {title}
    </Anchor>
    <div class="flex gap-3 text-sm shrink-0">
      {
        githubUrl ? (
          <Anchor url={githubUrl} class="text-sm" external>
            GitHub
          </Anchor>
        ) : null
      }
      {
        liveUrl ? (
          <Anchor url={liveUrl} class="text-sm" external>
            Live
          </Anchor>
        ) : null
      }
    </div>
  </div>
  <p class="text-muted text-base font-sans leading-relaxed max-w-3xl">
    {description}
  </p>
  <div class="flex flex-row flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="px-2 py-1 text-xs font-semibold text-accent border border-accent">
          {tag}
        </span>
      ))
    }
  </div>
</div>
