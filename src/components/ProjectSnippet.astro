---
import Anchor from "./common/Anchor.astro";

export type Props = {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  liveUrl?: string;
  tags: string[];
};

const { title, description, url, githubUrl, liveUrl, tags } = Astro.props;
---

<div class="flex flex-col gap-3 py-5 border-b border-zag-dark/15 dark:border-zag-light/15">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <Anchor url={url} class="text-lg">
      {title}
    </Anchor>
    <div class="flex gap-3 text-sm shrink-0">
      {
        githubUrl ? (
          <Anchor url={githubUrl} class="text-sm" external>
            GitHub
          </Anchor>
        ) : null
      }
      {
        liveUrl ? (
          <Anchor url={liveUrl} class="text-sm" external>
            Live
          </Anchor>
        ) : null
      }
    </div>
  </div>
  <p class="zag-muted zag-transition text-sm leading-7 max-w-[var(--content-width)]">
    {description}
  </p>
  <div class="flex flex-row flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="zag-transition px-2 py-1 text-xs font-semibold text-zag-accent-dark dark:text-zag-accent-light border border-zag-accent-dark dark:border-zag-accent-light">
          {tag}
        </span>
      ))
    }
  </div>
</div>
