---
export type Props = {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  liveUrl?: string;
  tags: string[];
  timestamp?: string;
};

const { title, description, url, githubUrl, liveUrl, tags, timestamp } = Astro.props;

function fmtMonthYear(iso: string) {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
  } catch { return iso; }
}
---

<a href={url} class="project-row">
  <div class="project-main">
    <div class="project-top">
      <span class="project-title">{title}</span>
      {timestamp && <span class="project-date">{fmtMonthYear(timestamp)}</span>}
    </div>
    <div class="project-desc">{description}</div>
    {tags.length > 0 && (
      <div class="project-tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
  <span class="project-read arrow-link">Read</span>
</a>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem 2rem;
    padding: 1.7rem 0;
    border-top: 1px solid var(--line-soft);
    text-decoration: none;
    align-items: baseline;
    transition: background 160ms ease;
  }
  .project-row:hover {
    background: var(--paper-deep);
    text-decoration: none;
  }

  .project-top {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin-bottom: 0.45rem;
  }

  .project-title {
    font-family: var(--mono);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .project-date {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
  }

  .project-desc {
    color: var(--ink-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.65rem;
    max-width: 42rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.65em;
  }

  .project-read {
    align-self: center;
  }

  @media (max-width: 540px) {
    .project-row { grid-template-columns: 1fr; }
    .project-read { display: none; }
  }
</style>
