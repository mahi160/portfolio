---
import ArticleSnippet from "../../components/ArticleSnippet.astro";
import Meta from "../../components/Meta.astro";
import Layout from "../../layouts/Layout.astro";
import { articles } from "../../lib/list";
import { GLOBAL } from "../../lib/variables";

// Group by year, newest first
const groups: Record<number, typeof articles> = {};
for (const a of articles) {
  const year = a.timestamp.getFullYear();
  (groups[year] ??= []).push(a);
}
const groupedYears = Object.entries(groups)
  .sort(([a], [b]) => Number(b) - Number(a))
  .map(([year, list]) => ({ year: Number(year), list }));
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${GLOBAL.blogTitle} • ${GLOBAL.username}`}
      description={GLOBAL.blogLongDescription}
      canonicalUrl={`${GLOBAL.rootUrl}/blog`}
    />
  </Fragment>

  <main id="main-content" class="wrap-narrow" tabindex="-1">
    <div class="page-head reveal">
      <div class="page-kicker">Writing</div>
      <h1>Notes from the workshop.</h1>
      <p class="page-lede">
        Developer tools, frontend systems, AI workflows, and terminal-first programming.
        Written when I have something to say — not on a schedule.
      </p>
    </div>

    <div class="year-groups reveal" style="--reveal-delay: 100ms">
      {groupedYears.map(({ year, list }) => (
        <div class="year-group">
          <div class="year-header">
            <span class="year-label">{year}</span>
            <span class="year-count">{list.length} {list.length === 1 ? "entry" : "entries"}</span>
          </div>
          <div class="year-articles">
            {list.map((article) => (
              <ArticleSnippet
                title={article.title}
                description={article.description}
                time={article.time}
                url={article.url}
                timestamp={article.timestamp}
              />
            ))}
            <div class="list-cap" aria-hidden="true"></div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .page-head {
    margin-bottom: 2.5rem;
    max-width: 44rem;
    padding-bottom: 0.5rem;
  }

  .page-kicker {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.8rem;
  }

  .page-head h1 {
    font-size: 2.6rem;
    font-style: italic;
    font-weight: 400;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .page-lede {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.65;
    margin: 0;
    max-width: 38rem;
  }

  .year-group {
    margin-bottom: 1.6rem;
  }

  .year-header {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 1.6rem;
    align-items: baseline;
    padding-bottom: 0.4rem;
  }

  .year-label {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--accent-deep);
    font-weight: 500;
  }

  .year-count {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .list-cap {
    border-top: 1px solid var(--line-soft);
  }
</style>
