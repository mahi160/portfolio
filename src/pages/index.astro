---
import FeaturedArticles from "../components/home/FeaturedArticles.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Hero from "../components/home/Hero.astro";
import Meta from "../components/Meta.astro";
import Layout from "../layouts/Layout.astro";
import { featuredArticles, featuredProjects } from "../lib/featured";
import { GLOBAL } from "../lib/variables";
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${GLOBAL.username} • ${GLOBAL.shortDescription}`}
      description={GLOBAL.longDescription}
      canonicalUrl={GLOBAL.rootUrl}
    />
  </Fragment>

  <main id="main-content" class="wrap-narrow" tabindex="-1">
    <!-- Hero -->
    <Hero />

    <!-- Now block -->
    <section class="now-block" aria-label="What I'm doing now">
      <div class="now-grid">
        <div class="now-label">
          Now
          <div class="now-date">{GLOBAL.nowDate}</div>
        </div>
        <div class="now-body" set:html={GLOBAL.nowBody} />
      </div>
    </section>

    <!-- Featured Writing -->
    <FeaturedArticles featuredArticles={featuredArticles} />

    <!-- Featured Projects -->
    <FeaturedProjects featuredProjects={featuredProjects} />

    <!-- Colophon -->
    <section class="colophon" aria-label="Current stack">
      <dl class="colophon-list">
        <div class="colophon-row">
          <dt>Working in</dt>
          <dd>TypeScript · Go · React</dd>
        </div>
        <div class="colophon-row">
          <dt>Living in</dt>
          <dd>Neovim · tmux · Ghostty</dd>
        </div>
        <div class="colophon-row">
          <dt>Building with</dt>
          <dd>SQLite · Bubble Tea · Astro</dd>
        </div>
        <div class="colophon-row">
          <dt>Reading about</dt>
          <dd>Local-first · TUI design · Small tools</dd>
        </div>
      </dl>
    </section>
  </main>
</Layout>

<style>
  /* Now block */
  .now-block {
    padding: 1.3rem 1.6rem;
    background: var(--paper-deep);
    border: 1px solid var(--line-soft);
    border-radius: 6px;
    margin-bottom: 3.5rem;
  }

  .now-grid {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .now-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-deep);
    padding-top: 0.15rem;
  }

  .now-date {
    color: var(--ink-faint);
    margin-top: 0.3rem;
    font-size: 0.7rem;
  }

  .now-body {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .now-body :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--line);
  }
  .now-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  /* Colophon */
  .colophon {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line-soft);
  }

  .colophon-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
  }

  .colophon-row {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .colophon-row dt {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .colophon-row dd {
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 540px) {
    .now-grid {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
  }
</style>
