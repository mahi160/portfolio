---
import FeaturedArticles from "../components/home/FeaturedArticles.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Hero from "../components/home/Hero.astro";
import Meta from "../components/Meta.astro";
import Layout from "../layouts/Layout.astro";
import { featuredArticles, featuredProjects } from "../lib/featured";
import { GLOBAL } from "../lib/variables";
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${GLOBAL.username} • ${GLOBAL.shortDescription}`}
      description={GLOBAL.longDescription}
      canonicalUrl={GLOBAL.rootUrl}
    />
  </Fragment>

  <main id="main-content" class="wrap" tabindex="-1">
    <!-- Hero -->
    <Hero />

    <!-- Now block -->
    <section class="now-block" aria-label="What I'm doing now">
      <div class="now-grid">
        <div class="now-label">
          Now
          <div class="now-date">{GLOBAL.nowDate}</div>
        </div>
        <div class="now-body" set:html={GLOBAL.nowBody} />
      </div>
    </section>

    <!-- Featured Writing -->
    <FeaturedArticles featuredArticles={featuredArticles} />

    <!-- Featured Projects -->
    <FeaturedProjects featuredProjects={featuredProjects} />

    <!-- Colophon -->
    <section class="colophon" aria-label="Current stack">
      <div class="colophon-grid">
        <div class="colophon-cell">
          <div class="colophon-label" id="col-working">Working in</div>
          <ul role="list" aria-labelledby="col-working">
            <li>TypeScript</li>
            <li>Go</li>
            <li>React</li>
          </ul>
        </div>
        <div class="colophon-cell">
          <div class="colophon-label" id="col-living">Living in</div>
          <ul role="list" aria-labelledby="col-living">
            <li>Neovim</li>
            <li>tmux</li>
            <li>Ghostty</li>
          </ul>
        </div>
        <div class="colophon-cell">
          <div class="colophon-label" id="col-building">Building with</div>
          <ul role="list" aria-labelledby="col-building">
            <li>SQLite</li>
            <li>Bubble Tea</li>
            <li>Astro</li>
          </ul>
        </div>
        <div class="colophon-cell">
          <div class="colophon-label" id="col-reading">Reading about</div>
          <ul role="list" aria-labelledby="col-reading">
            <li>Local-first</li>
            <li>TUI design</li>
            <li>Small tools</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Now block */
  .now-block {
    padding: 1.3rem 1.6rem;
    background: var(--paper-deep);
    border: 1px solid var(--line-soft);
    border-radius: 6px;
    margin-bottom: 3.5rem;
  }

  .now-grid {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .now-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-deep);
    padding-top: 0.15rem;
  }

  .now-date {
    color: var(--ink-faint);
    margin-top: 0.3rem;
    font-size: 0.7rem;
  }

  .now-body {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .now-body :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--line);
  }
  .now-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  /* Colophon */
  .colophon {
    margin-top: 3.5rem;
  }

  .colophon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1.8rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--line-soft);
  }

  .colophon-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.7rem;
  }

  .colophon-cell ul {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--ink-soft);
  }

  .colophon-cell li {
    padding: 0.18rem 0;
    font-size: 0.98rem;
  }

  @media (max-width: 540px) {
    .now-grid {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
  }
</style>
