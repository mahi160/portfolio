---
import Layout from "../../layouts/Layout.astro";
import Meta from "../../components/Meta.astro";
import ProjectSnippet from "../../components/ProjectSnippet.astro";
import { projects } from "../../lib/list";
import { GLOBAL } from "../../lib/variables";
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${GLOBAL.projectTitle} • ${GLOBAL.username}`}
      description={GLOBAL.projectLongDescription}
      canonicalUrl={`${GLOBAL.rootUrl}/projects`}
    />
  </Fragment>

  <main id="main-content" class="wrap" tabindex="-1">
    <div class="page-head">
      <div class="page-kicker">Projects</div>
      <h1>Things I made on purpose.</h1>
      <p class="page-lede">
        Developer tools and frontend experiments. Mostly small, focused, terminal-leaning —
        built around real workflows rather than ideas of products.
      </p>
    </div>

    <div class="project-list">
      {projects.map((project) => (
        <ProjectSnippet
          title={project.title}
          description={project.description}
          url={project.url}
          tags={project.tags ?? []}
          timestamp={project.timestamp}
        />
      ))}
      <div class="list-cap" aria-hidden="true"></div>
    </div>
  </main>
</Layout>

<style>
  .page-head {
    margin-bottom: 2.5rem;
    max-width: 44rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line-soft);
  }

  .page-kicker {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.8rem;
  }

  .page-head h1 {
    font-size: 2.6rem;
    font-family: var(--mono);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .page-lede {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.65;
    margin: 0;
    max-width: 38rem;
  }

  .list-cap {
    border-top: 1px solid var(--line-soft);
  }
</style>
