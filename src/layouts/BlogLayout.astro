---
import type { CollectionEntry } from "astro:content";
import { GLOBAL } from "../lib/variables";
import { formatDateLong, formatReadingTime, generateSourceUrl } from "../lib/utils";
import Meta from "../components/Meta.astro";
import ReadingControls from "../components/ReadingControls.astro";
import Layout from "./Layout.astro";

type Props = {
  frontmatter: CollectionEntry<"blog">["data"];
  slug: string;
};

const { frontmatter, slug } = Astro.props;
const canonicalUrl = generateSourceUrl(slug, "blog");
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${frontmatter.title} • ${GLOBAL.username}`}
      description={frontmatter.description}
      canonicalUrl={canonicalUrl}
      ogType="article"
    />
  </Fragment>

  <div class="read-progress" id="readProgress" aria-hidden="true"></div>

  <main id="main-content" class="wrap-narrow" tabindex="-1">
    <a href="/blog" class="back-link">← All writing</a>

    <article>
      <header class="article-header reveal">
        <div class="article-meta">
          <span class="article-date">{formatDateLong(frontmatter.timestamp)}</span>
          <span aria-hidden="true">·</span>
          <span>{formatReadingTime(frontmatter.time)}</span>
        </div>

        <h1 class="article-title">{frontmatter.title}</h1>

        <p class="article-lede">{frontmatter.description}</p>

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="tag-row">
            {frontmatter.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
      </header>

      <div class="article-rule" aria-hidden="true"></div>

      <ReadingControls />
      <div class="prose-warm">
        <slot />
      </div>

      <hr />

      <a href="/blog" class="back-link" style="margin-top: 2.5rem; margin-bottom: 0;">← All writing</a>
    </article>
  </main>
</Layout>

<script>
  const bar = document.getElementById("readProgress");
  const article = document.querySelector("article");

  function update() {
    if (!bar || !article) return;
    const rect = article.getBoundingClientRect();
    const total = rect.height - window.innerHeight;
    const read = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
    bar.style.transform = `scaleX(${total > 0 ? read / total : 0})`;
  }

  update();
  window.addEventListener("scroll", update, { passive: true });
  window.addEventListener("resize", update, { passive: true });
</script>

<style>
  .read-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 200;
    width: 100%;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    pointer-events: none;
  }

  .back-link {
    font-family: var(--mono);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 1.8rem;
  }
  .back-link:hover { color: var(--ink); text-decoration: none; }

  .article-header { margin-bottom: 1.8rem; }

  .article-meta {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .article-date { color: var(--accent-deep); }

  .article-title {
    font-size: 2.1rem;
    line-height: 1.12;
    margin-bottom: 1rem;
    font-variation-settings: "opsz" 60;
    font-weight: 400;
    letter-spacing: -0.015em;
  }

  .article-lede {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--ink-muted);
    margin-bottom: 1.6rem;
    font-style: italic;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.65em;
  }

  .article-rule {
    width: 3rem;
    border-top: 1px solid var(--accent);
    margin-bottom: 1.8rem;
  }

  @media (max-width: 540px) {
    .article-title { font-size: 1.8rem; }
  }
</style>
