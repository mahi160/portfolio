---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NF47Y6H8BL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-NF47Y6H8BL");
    </script>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function(){
        var t=localStorage.getItem("sifat-theme");
        if(t==="neon")          document.documentElement.setAttribute("data-theme","neon");
        else if(t==="dark"||(!t&&window.matchMedia("(prefers-color-scheme: dark)").matches)) document.documentElement.setAttribute("data-theme","dark");
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&display=swap"
    />

    <slot name="head" />

    <!-- Konami code easter egg: ↑↑↓↓←→←→ B A -->
    <script is:inline>
      (function(){
        var SEQ=['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
        var idx=0;
        document.addEventListener('keydown',function(e){
          idx = (e.key===SEQ[idx]) ? idx+1 : (e.key===SEQ[0] ? 1 : 0);
          if(idx===SEQ.length){
            idx=0;
            var root=document.documentElement;
            var cur=localStorage.getItem('sifat-theme')||'light';
            if(cur==='neon'){
              root.setAttribute('data-theme','dark');
              localStorage.setItem('sifat-theme','dark');
            } else {
              root.setAttribute('data-theme','neon');
              localStorage.setItem('sifat-theme','neon');
              var el=document.createElement('div');
              el.className='neon-toast';
              el.textContent='// konami: neon mode unlocked';
              document.body.appendChild(el);
              setTimeout(function(){el.classList.add('neon-toast--out');},2200);
              setTimeout(function(){el.remove();},3100);
            }
          }
        });
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="app">
      <Header />
      <div class="page-content">
        <slot />
      </div>
      <Footer />
    </div>
  </body>
</html>

<style>
  .app {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .page-content {
    flex: 1;
  }
</style>
