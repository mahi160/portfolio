---
import type { CollectionEntry } from "astro:content";
import { GLOBAL } from "../lib/variables";
import { formatMonthYear, generateSourceUrl } from "../lib/utils";
import CodeCopy from "../components/CodeCopy.astro";
import Meta from "../components/Meta.astro";
import ReadingControls from "../components/ReadingControls.astro";
import Layout from "./Layout.astro";

type Props = {
  frontmatter: CollectionEntry<"projects">["data"];
  slug: string;
};

const { frontmatter, slug } = Astro.props;
const canonicalUrl = generateSourceUrl(slug, "projects");
---

<Layout>
  <Fragment slot="head">
    <Meta
      title={`${frontmatter.title} • ${GLOBAL.username}`}
      description={frontmatter.description}
      canonicalUrl={canonicalUrl}
      ogImage={`${GLOBAL.rootUrl}/og/projects/${slug}.png`}
      ogType="article"
    />
  </Fragment>

  <main id="main-content" class="wrap-narrow" tabindex="-1">
    <a href="/projects" class="back-link">← All projects</a>

    <article>
      <header class="project-header reveal">
        <div class="project-kicker">
          Project&nbsp;&nbsp;·&nbsp;&nbsp;{formatMonthYear(frontmatter.timestamp)}
        </div>

        <h1 class="project-title">{frontmatter.title}</h1>

        <p class="project-desc">{frontmatter.description}</p>

        <div class="project-links">
          {frontmatter.githubUrl && (
            <a href={frontmatter.githubUrl} target="_blank" rel="noopener noreferrer" class="pill pill-accent" aria-label="View on GitHub, opens in new tab">
              GitHub ↗
            </a>
          )}
          {frontmatter.liveUrl && (
            <a href={frontmatter.liveUrl} target="_blank" rel="noopener noreferrer" class="pill" aria-label="View live site, opens in new tab">
              Live ↗
            </a>
          )}
        </div>

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="tag-row">
            {frontmatter.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
      </header>

      <div class="project-rule" aria-hidden="true"></div>

      <ReadingControls />
      <div class="prose-warm">
        <slot />
      </div>
      <CodeCopy />
    </article>
  </main>
</Layout>

<style>
  .back-link {
    font-family: var(--mono);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 1.8rem;
  }
  .back-link:hover { color: var(--ink); text-decoration: none; }

  .project-header { margin-bottom: 1.8rem; }

  .project-kicker {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 1rem;
  }

  .project-title {
    font-family: var(--mono);
    font-size: 2.2rem;
    font-weight: 500;
    margin-bottom: 0.9rem;
    letter-spacing: -0.02em;
  }

  .project-desc {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--ink-muted);
    margin-bottom: 1.1rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .pill-accent {
    border-color: var(--accent);
    color: var(--accent-deep);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.65em;
  }

  .project-rule {
    width: 3rem;
    border-top: 1px solid var(--accent);
    margin-bottom: 1.8rem;
  }

  @media (max-width: 540px) {
    .project-title { font-size: 1.8rem; }
  }
</style>
