---
import type { MarkdownLayoutProps } from "astro";
import Anchor from "../components/common/Anchor.astro";
import Section from "../components/common/Section.astro";
import Prose from "../components/Prose.astro";
import type { ProjectFrontmatter } from "../lib/types";
import { generateSourceUrl, getShortDescription } from "../lib/utils";
import { GLOBAL } from "../lib/variables";
import Layout from "./Layout.astro";


type Props = MarkdownLayoutProps<ProjectFrontmatter>;

const { frontmatter } = Astro.props;
const shortDescription = getShortDescription(frontmatter.description);
const sourceUrl = generateSourceUrl(frontmatter.filename, "projects");
---

<Layout>
  <Fragment slot="head">
    <title>{frontmatter.title} • {GLOBAL.username}</title>
    <meta name="description" content={frontmatter.description} />
    <meta property="og:title" content={`${frontmatter.title} • ${GLOBAL.username}`} />
    <meta property="og:description" content={shortDescription} />
    <meta property="og:image" content={`${GLOBAL.rootUrl}/${GLOBAL.profileImage}`} />
    <meta property="og:url" content={frontmatter.url} />
    <meta name="linkedin:card" content="summary_large_image" />
    <meta name="linkedin:title" content={`${frontmatter.title} • ${GLOBAL.username}`} />
    <meta name="linkedin:description" content={shortDescription} />
    <meta name="linkedin:image" content={`${GLOBAL.rootUrl}/${GLOBAL.profileImage}`} />
    <meta http-equiv="content-language" content="en" />
    <meta name="language" content="English" />
    <link rel="canonical" href={sourceUrl} />
  </Fragment>
  <Section class="py-12">
    <header class="flex flex-col gap-4 mb-10 max-w-[var(--content-width)]">
      <p class="text-xs uppercase tracking-[0.2em] font-mono zag-muted zag-transition">
        Project
      </p>
      <h1 class="text-3xl sm:text-4xl leading-tight font-display text-zag-accent-dark dark:text-zag-accent-light">
        {frontmatter.title}
      </h1>
      <div class="flex text-xs gap-2 flex-wrap">
        {
          frontmatter.tags
            ? frontmatter.tags.map((tag) => (
                <span class="zag-transition font-semibold py-1 px-2 text-xs text-zag-accent-dark dark:text-zag-accent-light border border-zag-accent-dark dark:border-zag-accent-light">
                  {tag}
                </span>
              ))
            : null
        }
      </div>
      <div class="flex gap-3 text-sm">
        {
          frontmatter.githubUrl ? (
            <Anchor url={frontmatter.githubUrl} class="text-sm" external>
              GitHub
            </Anchor>
          ) : null
        }
        {
          frontmatter.liveUrl ? (
            <Anchor url={frontmatter.liveUrl} class="text-sm" external>
              Live
            </Anchor>
          ) : null
        }
      </div>
    </header>
    <Prose>
      <slot />
    </Prose>
  </Section>
</Layout>
